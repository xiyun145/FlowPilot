# FlowPilot 环境变量配置模板
# 复制此文件为 .env 并填入你的实际配置

# 服务端口
PORT=3210

# 数据加密密钥（32位随机字符串，用于AES-256-GCM加密凭证）
# 首次使用请生成一个随机密钥：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-char-encryption-key-here

# 微信公众号配置（可选，也可在界面中配置）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=

# Google Gemini API Key（可选，也可在界面中配置）
GEMINI_API_KEY=

# SMTP邮件配置（可选，也可在界面中配置）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
